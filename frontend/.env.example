# Copy to .env.local and fill in your values

# Backend API URL
# - Local dev:    leave blank (CRA proxy in package.json handles it)
# - Vercel prod:  set to your Railway backend URL, e.g. https://stock-analyzer-backend.up.railway.app
REACT_APP_API_BASE_URL=

# App name displayed in header
REACT_APP_NAME=Stock Fundamental Analyser

